# .env.example
# Copy this file to .env and fill in your values before running docker compose up

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DB_USER=mms_admin
DB_PASSWORD=change_me_to_a_strong_password
DB_NAME=mms

# ─────────────────────────────────────────
# API
# ─────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars
API_PORT=3000
NODE_ENV=production

# ─────────────────────────────────────────
# IFC SERVICE
# ─────────────────────────────────────────
IFC_PORT=8000

# ─────────────────────────────────────────
# WEB FRONTEND
# ─────────────────────────────────────────
WEB_PORT=80
API_URL=http://localhost:3000
